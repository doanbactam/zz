# ZeroZero — .env example
# Copy to .env and fill in your API key. .env is gitignored.
#
# Preferred (OpenCode-style, no secrets in the project tree):
#   zz auth login xai --key xai-...
#   zz auth list
# Keys are stored in ~/.config/zerozero/auth.json (override: ZZ_AUTH_PATH).
# Environment variables always win over the auth store.

# Default provider: xAI (Grok)
XAI_API_KEY=xai-...

# Alternative providers (set ZZ_PROVIDER to switch):
# ZZ_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ZZ_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ZZ_PROVIDER=gemini
# GEMINI_API_KEY=...
# (also accepts GOOGLE_API_KEY)

# ZZ_PROVIDER=openrouter
# OPENROUTER_API_KEY=...

# ZZ_PROVIDER=groq
# GROQ_API_KEY=...

# ZZ_PROVIDER=deepseek
# DEEPSEEK_API_KEY=...

# ZZ_PROVIDER=together
# TOGETHER_API_KEY=...

# ZZ_PROVIDER=fireworks
# FIREWORKS_API_KEY=...

# ZZ_PROVIDER=mistral
# MISTRAL_API_KEY=...

# ZZ_PROVIDER=ollama
# ZZ_MODEL=llama3.2

# Optional overrides:
# ZZ_MODEL=grok-4
# XAI_BASE_URL=https://api.x.ai/v1
# ZZ_SANDBOX=workspace-write
# ZZ_APPROVAL=on-request
# ZZ_MAX_TURNS=10
# ZZ_AUTH_PATH=C:\path\to\auth.json
